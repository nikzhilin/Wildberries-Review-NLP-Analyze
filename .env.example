# PostgreSQL connection
DATABASE_URL=postgresql://wb:wb@localhost:5432/wb_reviews

# HuggingFace dataset
HF_DATASET=nyuuzyou/wb-feedbacks
MAX_ROWS=400000

# Marketplace tag written to the products table
MARKETPLACE=wildberries

# Batch sizes
BATCH_SIZE=5000           # DB insert batch (preprocess.py)
SENTIMENT_BATCH_SIZE=64   # reviews per inference call (sentiment)
EMBEDDING_BATCH_SIZE=128  # reviews per inference call (embeddings)

# Model names (HuggingFace model IDs)
SENTIMENT_MODEL=seara/rubert-tiny2-russian-sentiment
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# BERTopic: skip products with fewer reviews than this
MIN_CLUSTER_REVIEWS=50
